# 虚拟环境
.venv/
venv/
env/

# Python 编译产物
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# 构建产物
build/
dist/
*.egg-info/
.eggs/

# 测试 & 覆盖率
.pytest_cache/
.coverage
htmlcov/

# 运行时生成的数据库
config/tasks.db

# 配置文件（含敏感信息如 API Key）
config/settings.yaml

# 隐藏文件 & 系统文件
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# 日志
*.log
logs/*
!logs/.gitkeep

# 文档（README.md 和 docs/ 除外）
*.md
!README.md
!README.en.md
!docs/*.md

# 媒体库（不上传实际媒体文件）
/media/

# 插件目录（保留目录结构，不上传插件文件）
/plugins/*
!plugins/.gitkeep
!plugins/hello_plugin/
